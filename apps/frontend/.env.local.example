# Server-side only: where the runtime proxy (app/api/[...path]/route.ts)
# forwards /api/* requests. Read at request time, not baked into the build,
# so the same image works across environments (e.g. compose sets this to
# http://api:3000). The browser never calls this directly (same-origin
# /api/* only).
BACKEND_URL=http://localhost:3000
